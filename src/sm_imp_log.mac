// -*- coding: utf-8 -*-

import rsexts;
import sm_imp_lib;

// В заголовке, в шапке два файла
file fileLog() txt 2048 append;
file fileTxtReport() txt 2048 write;

class CImportLog( nameFile, nameFileTxt )
    var flagOpenLog = false, flagOpenTxt = false; // признаковое: открыт ли файл
    var strFile; // текущая строка файла
    var {curdate};
    var {oper};

    var count = 0, countErr = 0; // количество записей и ошибок

    macro Constructor( nameFile, nameFileTxt )
       var listFile = TDirList();

       listFile.List(nameFile, "F");

       if(listFile.Count == 0)
          // создаём файл
          flagOpenLog = Open( fileLog, nameFile );
          strFile = "                      Отчёт по обработке \"Импорт платежей Smarty\"\n";
          insert(fileLog, strFile);
       else
          flagOpenLog = Open( fileLog, nameFile );
       end;
       // создаём файл для текстового отчёта при необходимости
       if( nameFileTxt )
          flagOpenTxt = Open( fileTxtReport, nameFileTxt );
          strFile = "                      Отчёт по обработке \"Импорт платежей Smarty\"\n";
          insert( fileTxtReport, strFile );
       end;
       strFile = "";
    end;
    // --- Деструктор ---
    macro Destructor
       // Закрываем файлы
       if( flagOpenLog )
          Close(fileLog);
       end;
       if( flagOpenTxt )
          Close(fileTxtReport);
          // если процесс не запущен планировщиком — показываем отчёт
          if (not IsShedulerRunning())
             ViewFile(fileTxtReport);
          end;
       end;
    end;
    // --- Ячейка фиксированной ширины ---
    macro Cell( str, size )
       return str + MkStr(" ", size-StrLen(str));
    end;

    // --- Заголовок отчёта ---
    macro print_header()

       strFile = "Дата обработки: " + String(Date()) + "  " + String(Time()) + "\n";
       insert( fileLog, strFile );
       if( flagOpenTxt )
          insert( fileTxtReport, strFile );
       end;

       strFile = "Дата операционного дня: " + String({curdate}) + "\n";
       insert( fileLog, strFile );
       if( flagOpenTxt )
          insert( fileTxtReport, strFile );
       end;

       strFile = "Наименование дня: " + "Опер день" + "\n";
       insert( fileLog, strFile );
       if( flagOpenTxt )
          insert( fileTxtReport, strFile );
       end;

       strFile = "Операционист: " + String({oper}) + "\n";
       insert( fileLog, strFile );
       if( flagOpenTxt )
          insert( fileTxtReport, strFile );
       end;
       strFile = "";
    end;

    // --- Заголовок таблицы записей из выгрузки Smarty ---
    macro print_table_header(filepath)
        if( strFile == "" ) // если пусто, то это заголовок
            strFile = "Файл: " + filepath + "\n"
                      "��������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������Ŀ\n"+
                      "�   � Номер     �    Дата   �    � Банк     �  Сумма+комис �    Сумма   �               Получатель           �    БИК    �    Корр. счёт    �               Назначение           �     Счёт           �     ИНН    �                     Сообщение            �  Ошибка                                                                                                                             �\n"+
                      "��������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������Ĵ";


            if( flagOpenTxt )
               insert( fileTxtReport, strFile );
            end;
        end;
        strFile = "";
    end;

    // --- Печать строки по платежу ---
    macro print_row(pmnt)

        var strError = "";
        var i = 0;
        if( pmnt.Errors.size() != 0 )
            while( i < pmnt.Errors.size() )
               strError = strError + pmnt.Errors[i];
               i = i + 1;
            end;
        end;

        //debugbreak();
        strFile = strFile + "�" + Cell(string(pmnt.pmnt.Item("NUM")            ), 15 ) + "�" +
                                  Cell(string(pmnt.pmnt.Item("PDATE")          ), 12 ) + "�" +
                                  Cell(string(pmnt.pmnt.Item("CARD_NUM")       ), 15 ) + "�" +
                                  Cell(string(pmnt.pmnt.Item("SUM_WITH_COMIS") ), 14 ) + "�" +
                                  Cell(string(pmnt.pmnt.Item("SUM")            ), 12 ) + "�" +
                                  Cell(string(pmnt.pmnt.Item("BANK")           ), 36 ) + "�" +
                                  Cell(string(pmnt.pmnt.Item("BIC")            ), 11 ) + "�" +
                                  Cell(string(pmnt.pmnt.Item("CORACC")         ), 21 ) + "�" +
                                  Cell(string(pmnt.pmnt.Item("FIO")            ), 36 ) + "�" +
                                  Cell(string(pmnt.pmnt.Item("ACC")            ), 21 ) + "�" +
                                  Cell(string(pmnt.pmnt.Item("INN")            ), 10 ) + "�" +
                                  Cell(string(pmnt.pmnt.Item("PURPOSE")        ), 10 ) + "�" +
                                  Cell(string(strError                         ), 133) + "�";

        if( flagOpenTxt )
           insert( fileTxtReport, strFile );
        end;
        strFile = "";
        if( pmnt.Errors.size() != 0 )
           countErr = countErr + 1;
        end;
        count = count + 1;
    end;

    // --- Печать строки об ошибке файла ---
    macro print_error(filepath, msg)

        private var namefile, extfile;
        SplitFile(filepath, namefile, extfile);

        strFile = "����������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������Ĵ";

        if( flagOpenTxt )
           insert( fileTxtReport, strFile );
        end;
        strFile = "�" + Cell(string(namefile ), 17 ) + "�" +
                        Cell(string(msg      ), 133) + "�";

        if( flagOpenTxt )
           insert( fileTxtReport, strFile );
        end;
        strFile = "����������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������Ĵ";

        if( flagOpenTxt )
           insert( fileTxtReport, strFile );
        end;

        strFile = "";
    end;


    // --- Подвал таблицы ---
    macro print_table_footer()
        if( strFile == "" )
            strFile = "����������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������";
            if( flagOpenTxt )
               insert( fileTxtReport, strFile );
            end;
        end;
        strFile = "";
    end;

    // --- Подвал отчёта ---
    macro print_footer()
       strFile = "\n" + "Операционист: " + {oper} + "\n\n";
       insert( fileLog, strFile );
       if( flagOpenTxt )
          insert( fileTxtReport, strFile );
       end;
       strFile = "";
    end;
    // --- Печать сообщения ---
    macro Msg(msg)
       strFile = strFile + msg;
       insert( fileLog, strFile );
       if( flagOpenTxt )
          insert( fileTxtReport, strFile );
       end;
    end;
    // --- Печать строки ---
    macro MsgLn(msg)
       insert( fileLog, msg );
       if( flagOpenTxt )
          insert( fileTxtReport, msg );
       end;
    end;

    // --- Печать в лог и отчёт ---
    macro print_to_log(module, lineno, level, msg, needtoreport)
       if (ValType(needtoreport) == V_UNDEF)
           needtoreport = False
       end;
       var str = string(module +"[LINE:" + lineno + "]# " + StrUpr(level) + "[" + date() + " " + time() + "]   " + msg);
       insert( fileLog, str );
       if( flagOpenTxt and needtoreport)
          insert( fileTxtReport, str );
       end;
    end;

    // --- Итоговая статистика ---
    macro print_total()
       strFile = "\nВсего обработано записей:   " + String(count);
       insert( fileLog, strFile );
       if( flagOpenTxt )
          insert( fileTxtReport, strFile );
       end;
       strFile = "Из них с ошибками:  " + String(countErr);
       insert( fileLog, strFile );
       if( flagOpenTxt )
          insert( fileTxtReport, strFile );
       end;

       count      = 0;
       countErr   = 0;
    end;

    Constructor( nameFile, nameFileTxt );
end;